{
  "name": "edumart-workspace",
  "private": true,
  "version": "1.0.0",
  "description": "EduMart — full-stack student marketplace (React + Express)",
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix server\" \"npm run dev --prefix EduMart\"",
    "dev:client": "npm run dev --prefix EduMart",
    "dev:server": "npm run dev --prefix server",
    "install:all": "npm install --prefix server && npm install --prefix EduMart",
    "build": "npm run build --prefix EduMart"
  },
  "workspaces": [
    "EduMart",
    "server"
  ],
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}

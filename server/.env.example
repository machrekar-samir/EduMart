PORT=5000
CLIENT_URL=http://localhost:5173
MONGODB_URI=mongodb://127.0.0.1:27017/edumart
# USE_MEMORY_DB=true   # force in-memory DB
# USE_MEMORY_DB=false  # fail if local Mongo is down (no fallback)
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Google OAuth (Web client ID for token verification)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Admin seed (optional — first admin email)
ADMIN_EMAIL=admin@college.edu
